# ─────────────────────────────────────────────────────────────
# YTDLv2 Backend — Environment Variables
# Copy this file to .env for local development.
# Set these in Koyeb dashboard for production.
# ─────────────────────────────────────────────────────────────

# CORS — comma-separated list of allowed frontend origins.
# Local dev: leave as-is.
# Production: set to your Vercel URL.
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Database — SQLite file path.
# In Docker: data/ dir is created and persisted.
# Local dev: ytdl.db in project root.
DATABASE_URL=sqlite:///./data/ytdl.db

# Temp directory — where downloads are staged before serving.
# Docker default: /home/appuser/app/temp (auto-created in Dockerfile)
# TEMP_DIR=/home/appuser/app/temp

# FFmpeg — leave blank to auto-detect from PATH (works in Docker).
# FFMPEG_PATH=/usr/bin/ffmpeg

# Optional: path to a YouTube cookies.txt file (for age-restricted videos).
# COOKIES_FILE=/home/appuser/app/cookies.txt
